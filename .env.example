# Base da API da Desenrola (produção)
DESENROLA_API_URL=https://api.desenrolasi.com

# publicId da sua conta API_CHANNEL (default: conta de teste "Teste API")
CHANNEL_ACCOUNT_ID=b74061de-e2cf-4670-a5cd-491ba8c716a7

# Secret de AUTENTICAÇÃO da conta — vai no header x-channel-secret ao ENVIAR.
# NUNCA fixe no código nem faça commit. Copie pra .env.local.
CHANNEL_SECRET=

# Secret do CALLBACK — usado pra validar o header X-Channel-Signature ao RECEBER.
# É um secret SEPARADO do CHANNEL_SECRET (configurado na aba Callback do painel).
CHANNEL_CALLBACK_SECRET=
